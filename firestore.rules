rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
             request.auth.token.email == 'zhangluohen@gmail.com' ||
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.size() >= 4 &&
               data.uid is string && data.uid == userId &&
               data.email is string && data.email.size() <= 256 &&
               data.role in ['user', 'admin'] &&
               data.displayName is string && data.displayName.size() <= 100;
      }

      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      (request.auth.token.email == 'zhangluohen@gmail.com' ? incoming().role == 'admin' : incoming().role == 'user');
      allow update: if (isOwner(userId) && 
                        isValidUser(incoming()) && 
                        incoming().role == existing().role) || 
                       isAdmin();
    }

    // Post Rules
    match /posts/{postId} {
      function isValidPost(data) {
        return data.keys().hasAll(['title', 'content', 'authorId', 'status', 'createdAt']) &&
               data.title is string && data.title.size() <= 200 &&
               data.content is string && data.content.size() <= 50000 &&
               data.authorId is string && data.authorId.size() <= 128 &&
               data.status in ['published', 'draft'] &&
               data.createdAt is timestamp;
      }
      
      function isPostAuthor() { return isOwner(existing().authorId); }

      allow read: if existing().status == 'published' || isPostAuthor() || isAdmin();
      allow create: if isSignedIn() && 
                      isValidPost(incoming()) && 
                      incoming().authorId == request.auth.uid &&
                      incoming().createdAt == request.time;
      allow update: if isSignedIn() && (
                      (isPostAuthor() && isValidPost(incoming()) && 
                       incoming().authorId == existing().authorId && 
                       incoming().createdAt == existing().createdAt) || 
                      isAdmin()
                    );
      allow delete: if isPostAuthor() || isAdmin();

      // Comments Rules (Nested)
      match /comments/{commentId} {
        function isValidComment(data) {
          return data.keys().hasAll(['postId', 'content', 'authorId', 'createdAt']) &&
                 data.postId == postId &&
                 data.content is string && data.content.size() <= 2000 &&
                 data.authorId is string &&
                 data.createdAt is timestamp;
        }

        allow read: if true;
        allow create: if isSignedIn() &&
                        isValidComment(incoming()) &&
                        incoming().authorId == request.auth.uid &&
                        incoming().createdAt == request.time;
        allow delete: if isOwner(existing().authorId) || 
                        get(/databases/$(database)/documents/posts/$(postId)).data.authorId == request.auth.uid ||
                        isAdmin();
      }
    }
  }
}
